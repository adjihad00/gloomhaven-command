{
  "name": "gloomhaven-command",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "server",
    "clients/display",
    "clients/controller",
    "clients/phone"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"node app/build.mjs --watch\"",
    "build": "npm run build --workspaces && node app/build.mjs",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:server": "npm run build --workspace=server",
    "build:clients": "npm run build --workspace=clients/display --workspace=clients/controller --workspace=clients/phone",
    "build:app": "node app/build.mjs",
    "watch:app": "node app/build.mjs --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "preact": "^10.29.0"
  }
}
